rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ZUCKKY AI SECURITY RULES
     * 
     * Core Philosophy: 
     * This ruleset enforces a strict user-ownership model. All user-specific data is hierarchically 
     * nested under a unique user path to ensure natural isolation and efficient querying. 
     * We utilize denormalized 'userId' and 'conversationId' fields to allow for atomic, 
     * high-performance authorization checks without requiring additional database lookups.
     * 
     * Data Structure:
     * - /users/{userId}: Private user profiles and the root of the ownership tree.
     * - /users/{userId}/conversations/...: Nested data for chat sessions, media, and jobs.
     * - /templates: Global, read-only configuration data for video styles.
     * 
     * Key Security Decisions:
     * 1. Path-Based Authorization: The UID in the document path must always match the authenticated user's UID.
     * 2. Prototyping Flexibility: While authorization is strictly enforced (who can access), 
     *    data schema validation (types and shapes) is omitted to allow for rapid frontend iteration.
     * 3. Relational Integrity: On creation and update, rules ensure that internal ownership 
     *    fields (like 'userId') remain consistent with the document path and authenticated identity.
     * 4. Admin Restrictions: Collections like 'templates' are restricted to read-only for users.
     */

    // --- HELPER FUNCTIONS ---

    /** @description Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks ownership and ensures the document exists for update/delete. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Validates that the data being written has the correct userId link. */
    function isValidUserLink(userId) {
      return request.resource.data.userId == userId;
    }

    /** @description Validates that the data being written has the correct conversationId link. */
    function isValidConversationLink(conversationId) {
      return request.resource.data.conversationId == conversationId;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the User profile. Only the user themselves can read or write their profile.
     * @path /users/{userId}
     * @allow (create) if auth.uid matches {userId}.
     * @deny (read) if auth.uid does not match {userId}.
     * @principle Self-creation and strict path-based ownership.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == userId;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for Conversations. A user owns all conversations under their path.
       * @path /users/{userId}/conversations/{conversationId}
       * @allow (list) if request.auth.uid == {userId}.
       * @deny (create) if the internal 'userId' field does not match the path.
       * @principle Denormalization for authorization independence.
       */
      match /conversations/{conversationId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidUserLink(userId);
        allow update: if isExistingOwner(userId) && isValidUserLink(userId);
        allow delete: if isExistingOwner(userId);

        /**
         * @description Rules for Messages within a conversation.
         * @path /users/{userId}/conversations/{conversationId}/messages/{messageId}
         * @allow (create) if the message's userId and conversationId match the path context.
         * @deny (update) if a user attempts to change the ownership field.
         * @principle Relational integrity and hierarchical access control.
         */
        match /messages/{messageId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && isValidUserLink(userId) && isValidConversationLink(conversationId);
          allow update: if isExistingOwner(userId) && isValidUserLink(userId) && isValidConversationLink(conversationId);
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Rules for MediaFiles (original footage) uploaded in a conversation.
         * @path /users/{userId}/conversations/{conversationId}/mediaFiles/{mediaFileId}
         * @allow (get) if the authenticated user is the path owner.
         * @deny (create) if the uploaded metadata points to a different user.
         * @principle Path-based isolation for sensitive media metadata.
         */
        match /mediaFiles/{mediaFileId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && isValidUserLink(userId) && isValidConversationLink(conversationId);
          allow update: if isExistingOwner(userId) && isValidUserLink(userId) && isValidConversationLink(conversationId);
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Rules for VideoEditingJobs. Tracks the status of AI processing.
         * @path /users/{userId}/conversations/{conversationId}/videoEditingJobs/{jobId}
         * @allow (update) if the owner is updating progress or status.
         * @deny (list) if the user is not the owner of the path.
         * @principle Resource-specific tracking within a user's private tree.
         */
        match /videoEditingJobs/{jobId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && isValidUserLink(userId) && isValidConversationLink(conversationId);
          allow update: if isExistingOwner(userId) && isValidUserLink(userId) && isValidConversationLink(conversationId);
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Rules for EditedVideos. Metadata for results of editing jobs.
         * @path /users/{userId}/conversations/{conversationId}/editedVideos/{editedVideoId}
         * @allow (get) if the user is the owner.
         * @deny (delete) if the document does not exist.
         * @principle Ensuring users can only access videos they commissioned.
         */
        match /editedVideos/{editedVideoId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && isValidUserLink(userId) && isValidConversationLink(conversationId);
          allow update: if isExistingOwner(userId) && isValidUserLink(userId) && isValidConversationLink(conversationId);
          allow delete: if isExistingOwner(userId);
        }
      }

      /**
       * @description Rules for CreditTransactions. Financial history for the user.
       * @path /users/{userId}/creditTransactions/{transactionId}
       * @allow (get) for personal accounting.
       * @deny (update) as transactions are typically immutable audit logs.
       * @principle Secure, private record-keeping of credit balance changes.
       */
      match /creditTransactions/{transactionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidUserLink(userId);
        allow update: if false; // Transactions should be immutable for integrity.
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Rules for Global Video Templates.
     * @path /templates/{templateId}
     * @allow (read) for all authenticated users to browse options.
     * @deny (write) for all users; templates are managed by system/admin.
     * @principle Public-read (authenticated) with restricted administrative writes.
     */
    match /templates/{templateId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false; // System/Admin managed only.
    }
  }
}